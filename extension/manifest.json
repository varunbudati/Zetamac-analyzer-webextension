{
  "name": "Zetamac → Obsidian",
  "version": "2.1.0",
  "manifest_version": 3,
  "description": "Automatically export Zetamac game results as Obsidian-flavored markdown notes with per-question analysis.",
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zetamac → Obsidian"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://arithmetic.zetamac.com/*"],
      "js": ["interceptor.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://arithmetic.zetamac.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "downloads",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://arithmetic.zetamac.com/*"
  ]
}
